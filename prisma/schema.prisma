// Safety Check — Prisma Schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

// ─── USERS ───────────────────────────────────────────────────────────────────

model User {
  id                   String     @id @default(cuid())
  phoneNumber          String     @unique
  firstName            String?
  address              String     @default("")
  city                 String     @default("")
  province             String     @default("")
  country              String     @default("")
  zipCode              String     @default("")
  fcmToken             String?
  lastLat              Float?
  lastLng              Float?
  status               UserStatus @default(ACTIVE)
  checkInIntervalHours Int        @default(24)   // legacy — utilisé comme fallback
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
  lastCheckInAt        DateTime?
  language             String     @default("fr")
  timezone String?
  alertChannel         String     @default("sms")
  alertSystemEnabled   Boolean    @default(true)
  notificationsEnabled Boolean    @default(true)

  // ── Schedule avancé ──────────────────────────────────────────────────────
  // scheduleType : "interval" | "weekly" | "monthly"
  scheduleType            String  @default("interval")
  // Pour interval : durée totale = scheduleIntervalHours * 60 + scheduleIntervalMinutes
  scheduleIntervalHours   Int     @default(24)
  scheduleIntervalMinutes Int     @default(0)
  // Pour weekly : jour de la semaine (0=Dim, 1=Lun, ..., 6=Sam)
  scheduleDayOfWeek       Int?
  // Pour monthly : jour du mois (1..31)
  scheduleDayOfMonth      Int?
  // Pour weekly et monthly : heure et minute du check-in
  scheduleTimeHour        Int     @default(9)
  scheduleTimeMinute      Int     @default(0)

  emergencyContact EmergencyContact?
  checkInEvents    CheckInEvent[]
  alertEvents      AlertEvent[]
}

enum UserStatus {
  ACTIVE
  PAUSED
  DELETED
}

// ─── EMERGENCY CONTACTS ──────────────────────────────────────────────────────

model EmergencyContact {
  id           String   @id @default(cuid())
  userId       String   @unique
  name         String
  phoneNumber  String
  relationship String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── CHECK-IN EVENTS ─────────────────────────────────────────────────────────

model CheckInEvent {
  id            String           @id @default(cuid())
  userId        String
  sentAt        DateTime         @default(now())
  respondedAt   DateTime?
  response      CheckInResponse?
  attemptNumber Int              @default(1)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum CheckInResponse {
  OK
  SOS
}

// ─── ALERT EVENTS ────────────────────────────────────────────────────────────

model AlertEvent {
  id            String      @id @default(cuid())
  userId        String
  triggerReason AlertReason
  triggeredAt   DateTime    @default(now())
  resolvedAt    DateTime?
  status        AlertStatus @default(ACTIVE)
  latAtTrigger  Float?
  lngAtTrigger  Float?

  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  actions AlertAction[]

  @@index([userId])
}

enum AlertReason {
  NO_RESPONSE_AFTER_2_ATTEMPTS
  NO_RESPONSE_AFTER_3_REMINDERS
  NO_RESPONSE_AFTER_5_REMINDERS
  USER_PRESSED_SOS
}

enum AlertStatus {
  ACTIVE
  RESOLVED
  CANCELLED
  FAILED
}

// ─── ALERT ACTIONS (audit log) ───────────────────────────────────────────────

model AlertAction {
  id            String   @id @default(cuid())
  alertId       String
  actionType    String
  destination   String?
  outcome       String
  providerSid   String?
  executedAt    DateTime @default(now())
  humanAnswered Boolean  @default(false)
  amdResult     String?
  callStatus    String?
  callDuration  Int?

  alert AlertEvent @relation(fields: [alertId], references: [id], onDelete: Cascade)

  @@index([alertId])
}

// ─── SUPPORT MESSAGES (formulaire Contactez-nous) ─────────────────────────────

model SupportMessage {
  id           String   @id @default(cuid())
  userId       String?
  subject      String
  message      String
  contactEmail String?
  status       String   @default("OPEN") // OPEN | IN_PROGRESS | RESOLVED
  createdAt    DateTime @default(now())

  @@index([status])
}
